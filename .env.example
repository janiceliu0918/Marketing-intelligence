# ── Bonvin Wine Market Intelligence Agent — Environment Variables ──────────────
# Copy this file to .env and fill in your credentials

# Required: Anthropic API key for Claude
ANTHROPIC_API_KEY=sk-ant-...

# Optional: Wine-Searcher commercial API key (falls back to web scraping)
WINE_SEARCHER_API_KEY=

# Optional: SQLite DB path (default: wine_intelligence.db in project root)
DATABASE_URL=sqlite:///wine_intelligence.db

# Output directory for report files
REPORTS_DIR=reports_output

# Exchange rates (update periodically — defaults used if not set)
CAD_USD_RATE=1.36
CAD_EUR_RATE=1.48
CAD_GBP_RATE=1.73
